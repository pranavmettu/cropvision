# Optional Pl@ntNet API key for advanced plant/species identification.
# Leave blank or unset to run CropVision with local models only.
PLANTNET_API_KEY=your_api_key_here

STREAMLIT_SERVER_PORT=8501

# Kaggle datasets use the standard Kaggle API credential flow.
# Do not put kaggle.json in this repo. Place it in ~/.kaggle/kaggle.json.
